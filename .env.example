# Copy this file to .env and fill in real values. .env is gitignored — never commit it.
# Loaded automatically at startup by DotNetEnv (see src/Edfx.Web/Program.cs).

# --- Moody's EDF-X credentials (required for live mode) ---
EDFX_USERNAME=your-moodys-username
EDFX_PASSWORD=your-moodys-password

# --- Supabase / Postgres (required for live mode; extractions are persisted here) ---
SUPABASE_DB_CONNECTION=Host=db.xxxx.supabase.co;Port=5432;Username=postgres;Password=your-password;Database=postgres;SSL Mode=Require;Trust Server Certificate=true

# --- Optional overrides (defaults shown) ---
# EDFX_BASE_URL=https://api.edfx.moodysanalytics.com/edfx/v1/
# EDFX_TOKEN_URL=https://sso.moodysanalytics.com/sso-api/v1/token

# Set to true to run with synthetic data — no credentials or DB needed.
EDFX_USE_MOCK=false
